NEXT_PUBLIC_SUPABASE_URL=https://rqqvlqbnhrxfeaaaxvhg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_z7-MvSvPnSIcE89YSQ9x_A_t3zqvU6Z

# Firebase AI Logic (Gemini) -- this is the Firebase web app config, not a secret key.
# Get these from the Firebase console: Project settings -> Your apps -> (web app) -> SDK setup and configuration.
# Also make sure Gemini is enabled for the project: Firebase console -> Build -> AI Logic -> Get started.
# Without these, everything else (scraping, manual entry, PDF download, history) still works,
# but "Tailor my resume" will return a clear setup error instead of crashing.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
